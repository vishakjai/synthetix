{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetix.example/schemas/business_rule_catalog_v1.json",
  "title": "Synthetix Business Rule Catalog v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "artifact_version", "metadata", "rules"],
  "properties": {
    "artifact_type": { "const": "business_rule_catalog" },
    "artifact_version": { "const": "1.0" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "context_reference", "skill_pack"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "context_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "commit_sha"],
          "properties": {
            "repo": { "type": "string" },
            "commit_sha": { "type": "string" }
          }
        },
        "skill_pack": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string" },
            "version": { "type": "string" }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["rule_id", "category", "statement"],
        "properties": {
          "rule_id": { "type": "string" },
          "category": {
            "enum": [
              "business_objective",
              "workflow_orchestration",
              "calculation_logic",
              "threshold_rule",
              "data_persistence",
              "validation_rule",
              "security_rule",
              "other"
            ]
          },
          "statement": { "type": "string" },
          "scope": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "project_id": { "type": "string" },
              "component_id": { "type": "string" }
            }
          },
          "evidence": {
            "type": "array",
            "items": { "$ref": "common_evidence_v1.schema.json" },
            "default": []
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "tags": { "type": "array", "items": { "type": "string" }, "default": [] }
        }
      }
    }
  }
}
