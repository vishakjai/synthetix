{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetix.example/schemas/legacy_inventory_v1.json",
  "title": "Synthetix Legacy Inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "artifact_version", "metadata", "summary", "projects"],
  "properties": {
    "artifact_type": { "const": "legacy_inventory" },
    "artifact_version": { "const": "1.0" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "skill_pack", "context_reference"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "skill_pack": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string" },
            "version": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "context_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "branch", "commit_sha"],
          "properties": {
            "repo": { "type": "string" },
            "branch": { "type": "string" },
            "commit_sha": { "type": "string" },
            "version_id": { "type": "string" }
          }
        },
        "source_language": { "type": "string" },
        "ecosystem": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["counts"],
      "properties": {
        "counts": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "projects": { "type": "integer", "minimum": 0 },
            "programs": { "type": "integer", "minimum": 0 },
            "modules": { "type": "integer", "minimum": 0 },
            "forms_or_screens": { "type": "integer", "minimum": 0 },
            "controls": { "type": "integer", "minimum": 0 },
            "dependencies": { "type": "integer", "minimum": 0 },
            "event_handlers": { "type": "integer", "minimum": 0 }
          }
        },
        "data_touchpoints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "modernization_readiness": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "score": { "type": "integer", "minimum": 0, "maximum": 100 },
            "tier": { "enum": ["low", "medium", "high"] },
            "recommended_strategy": { "type": "string" },
            "required_actions": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["project_id", "name", "type", "members"],
        "properties": {
          "project_id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "startup": { "type": "string" },
          "file": { "type": "string" },
          "business_hypothesis": { "type": "string" },
          "capabilities": { "type": "array", "items": { "type": "string" } },
          "members": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "kind", "path"],
              "properties": {
                "id": { "type": "string" },
                "kind": {
                  "enum": [
                    "program",
                    "module",
                    "class",
                    "form",
                    "screen",
                    "report",
                    "copybook",
                    "jcl",
                    "proc",
                    "synon_function",
                    "other"
                  ]
                },
                "path": { "type": "string" },
                "display_name": { "type": "string" },
                "evidence": {
                  "type": "array",
                  "items": { "$ref": "common_evidence_v1.schema.json" },
                  "default": []
                }
              }
            }
          },
          "ui_assets": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "kind", "name"],
              "properties": {
                "id": { "type": "string" },
                "kind": { "enum": ["form", "screen", "display_file", "bms_map", "report"] },
                "name": { "type": "string" },
                "controls_count": { "type": "integer", "minimum": 0 },
                "event_handlers_count": { "type": "integer", "minimum": 0 }
              }
            },
            "default": []
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "file_coverage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "by_type": {
                "type": "object",
                "additionalProperties": { "type": "integer", "minimum": 0 }
              },
              "binary_companions": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
