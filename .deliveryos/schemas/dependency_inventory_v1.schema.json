{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://synthetix.example/schemas/dependency_inventory_v1.json",
  "title": "Synthetix Dependency Inventory v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["artifact_type", "artifact_version", "metadata", "dependencies"],
  "properties": {
    "artifact_type": { "const": "dependency_inventory" },
    "artifact_version": { "const": "1.0" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generated_at", "skill_pack", "context_reference"],
      "properties": {
        "generated_at": { "type": "string", "format": "date-time" },
        "skill_pack": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version"],
          "properties": {
            "id": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "context_reference": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repo", "commit_sha"],
          "properties": {
            "repo": { "type": "string" },
            "commit_sha": { "type": "string" }
          }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["dependency_id", "name", "kind"],
        "properties": {
          "dependency_id": { "type": "string" },
          "name": { "type": "string" },
          "kind": {
            "enum": [
              "ocx",
              "dll",
              "com_typelib",
              "nuget",
              "npm",
              "jar",
              "ibmi_object",
              "ibmi_service_program",
              "ibmi_binding_directory",
              "external_system",
              "other"
            ]
          },
          "version": { "type": "string" },
          "source": { "type": "string" },
          "usage": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "used_by": { "type": "array", "items": { "type": "string" } },
              "usage_sites": {
                "type": "array",
                "items": { "$ref": "common_evidence_v1.schema.json" },
                "default": []
              }
            }
          },
          "surface": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "prog_ids": { "type": "array", "items": { "type": "string" }, "default": [] },
              "class_ids": { "type": "array", "items": { "type": "string" }, "default": [] },
              "late_binding_sites": { "type": "integer", "minimum": 0, "default": 0 },
              "callbyname_sites": { "type": "integer", "minimum": 0, "default": 0 }
            }
          },
          "risk": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "tier": { "enum": ["low", "medium", "high"] },
              "notes": { "type": "string" },
              "recommended_action": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
